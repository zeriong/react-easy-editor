{
  "name": "@react-easy-editor/core",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": ["*.css"],
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lexical": ">=0.28.0",
    "@lexical/react": ">=0.28.0"
  },
  "dependencies": {
    "@lexical/html": "0.34.0",
    "@lexical/rich-text": "0.34.0",
    "@lexical/selection": "0.34.0",
    "zustand": "^5.0.8",
    "dompurify": "^3.2.6",
    "framer-motion": "^12.23.12"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "lexical": "0.34.0",
    "@lexical/react": "0.34.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/dompurify": "^3.2.0",
    "typescript": "^5.8.0",
    "tsup": "^8.0.0"
  }
}
