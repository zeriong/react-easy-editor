{
  "name": "react-easy-editor",
  "version": "0.0.1",
  "description": "All-in-one rich text editor for React, powered by Lexical",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lexical": ">=0.28.0",
    "@lexical/react": ">=0.28.0"
  },
  "dependencies": {
    "@react-easy-editor/core": "workspace:*",
    "@react-easy-editor/toolbar": "workspace:*",
    "@react-easy-editor/history": "workspace:*",
    "@react-easy-editor/text-style": "workspace:*",
    "@react-easy-editor/text-color": "workspace:*",
    "@react-easy-editor/alignment": "workspace:*",
    "@react-easy-editor/block-type": "workspace:*",
    "@react-easy-editor/image": "workspace:*",
    "@react-easy-editor/video": "workspace:*",
    "@react-easy-editor/table": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "lexical": "0.34.0",
    "@lexical/react": "0.34.0",
    "typescript": "^5.8.0",
    "tsup": "^8.0.0"
  },
  "keywords": [
    "react",
    "editor",
    "rich-text",
    "lexical",
    "wysiwyg",
    "react-easy-editor"
  ],
  "license": "MIT"
}
