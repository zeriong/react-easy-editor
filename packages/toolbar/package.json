{
  "name": "@react-easy-editor/toolbar",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "lexical": ">=0.28.0",
    "@react-easy-editor/core": "workspace:*"
  },
  "dependencies": {
    "@react-easy-editor/core": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "@types/react": "^19.1.0",
    "lexical": "0.34.0",
    "@lexical/react": "0.34.0",
    "typescript": "^5.8.0",
    "tsup": "^8.0.0"
  }
}
