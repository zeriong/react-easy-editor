{
  "name": "react-easy-editor",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo watch dev build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0"
    }
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
